# ─────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your real credentials.
#   cp .env.example .env
# Never commit your real .env file.
# ─────────────────────────────────────────────────────────────

# Where the app runs locally
PORT=8585
BASE_URL=http://localhost:8585

# Secret used to sign session cookies (any long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# ── Microsoft Azure (Outlook / Microsoft Graph) ──
# From: Azure Portal > App registrations > your app
MICROSOFT_CLIENT_ID=your-azure-application-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret-value
# Use "common" to allow both work/school and personal Microsoft accounts,
# or your specific tenant ID to restrict to your organization only.
MICROSOFT_TENANT=common

# ── Google Cloud (Google Calendar) ──
# From: Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
